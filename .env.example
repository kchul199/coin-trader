# ─── Database ─────────────────────────────────────────────
# Docker Compose 내부: postgresql+asyncpg://cointrader:secret@postgres/cointrader
# 로컬 직접 실행 시:   postgresql+asyncpg://cointrader:secret@localhost:5432/cointrader
DATABASE_URL=postgresql+asyncpg://cointrader:secret@postgres/cointrader

# ─── Redis ────────────────────────────────────────────────
# Docker Compose 내부: redis://redis:6379/0
# 로컬 직접 실행 시:   redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────
# 운영 시 반드시 32바이트 이상 랜덤 값으로 교체 (openssl rand -hex 32)
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ─── Exchange ─────────────────────────────────────────────
EXCHANGE_ID=binance
USE_TESTNET=true
QUOTE_CURRENCY=USDT

# ─── Anthropic AI ─────────────────────────────────────────
# https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
