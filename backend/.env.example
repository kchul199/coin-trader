# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/coin_trader

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Exchange Configuration
EXCHANGE_ID=binance
USE_TESTNET=True
QUOTE_CURRENCY=USDT
ALLOWED_EXCHANGE_IDS=binance,kraken,coinbase

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AI_CONSULT_TIMEOUT_SECONDS=5

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379

# API Configuration
API_V1_STR=/api/v1
